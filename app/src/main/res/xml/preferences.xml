<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">
    <SwitchPreferenceCompat
        android:key="voice_enabled"
        android:title="Voice Commands"
        android:defaultValue="true"/>
    <SwitchPreferenceCompat
        android:key="wake_word_enabled"
        android:title="Wake Word Detection"
        android:defaultValue="true"/>
    <SwitchPreferenceCompat
        android:key="hinglish_support"
        android:title="Hinglish Support"
        android:defaultValue="true"/>
    <ListPreference
        android:key="language"
        android:title="Language"
        android:entries="@array/language_entries"
        android:entryValues="@array/language_values"
        android:defaultValue="hinglish"/>
</PreferenceScreen>
